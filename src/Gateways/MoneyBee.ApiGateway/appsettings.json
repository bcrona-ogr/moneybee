{
  "Jwt": {
    "Issuer": "MoneyBee.Auth",
    "Audience": "MoneyBee.Services",
    "SecretKey": "MoneyBee_Local_Dev_HS256_Key_2026_X9mP4qR7tV2wY8zK5nL1cD6sF3hJ0",
    "AccessTokenExpirationMinutes": 60
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/gateway/api/auth/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/gateway" }
        ]
      },
      "customer-route": {
        "ClusterId": "customer-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/gateway/api/customers/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/gateway" }
        ]
      },
      "transfer-route": {
        "ClusterId": "transfer-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/gateway/api/transfers/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/gateway" }
        ]
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "d1": {
            "Address": "https://localhost:7001/"
          }
        }
      },
      "customer-cluster": {
        "Destinations": {
          "d1": {
            "Address": "https://localhost:7002/"
          }
        }
      },
      "transfer-cluster": {
        "Destinations": {
          "d1": {
            "Address": "https://localhost:7003/"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp.ReverseProxy": "Information"
    }
  }
}